# Local PostgreSQL database used by Prisma and the API.
DATABASE_URL="postgresql://babyshare:babyshare@localhost:5432/babyshare?schema=public"

# Local-development JWT signing secret. Replace with a strong secret outside local dev.
JWT_SECRET="babyshare-local-development-jwt-secret-change-before-production"

# Local email testing through Mailpit.
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
MAIL_FROM="BabyShare <no-reply@babyshare.local>"
